<!--components/Card_Cell/Cell.wxml-->
<view class="cell-voltage-container">
  <!-- 标题 -->
  <view class="title">{{title}}</view>
  <!-- 单体电压网格 -->
  <view class="cell-grid">
    <view 
      wx:for="{{displayArray}}" 
      wx:for-index="idx"
      wx:key="idx" 
      class="cell-item"
      data-index="{{idx}}"
      bindtap="onCellTap"
    >
      <view class="cell-button">
        <view class="cell-index">单体{{idx + 1}}</view>
        <view class="cell-value">{{item}}{{unit}}</view>
      </view>
    </view>
  </view>
</view>