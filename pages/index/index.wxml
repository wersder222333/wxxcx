
<!--数据栏-->
<view class="content-area">
  <view class="card-container">
    <view class="nav-card" bindtap="gotoBLEScan">
      <view class="card-icon">📡</view>
      <view class="card-text">
        <view class="card-title">蓝牙扫描</view>
        <view class="card-desc">搜索并连接蓝牙设备</view>
      </view>
      <view class="card-arrow">›</view>
    </view>
    
    <view class="nav-card" bindtap="gotoDataOverview">
      <view class="card-icon">🔋</view>
      <view class="card-text">
        <view class="card-title">数据概览</view>
        <view class="card-desc">查看电池实时数据</view>
      </view>
      <view class="card-arrow">›</view>
    </view>
    
    <view class="nav-card" bindtap="gotoDataDetail">
      <view class="card-icon">📊</view>
      <view class="card-text">
        <view class="card-title">详细数据</view>
        <view class="card-desc">查看单体电压和温度</view>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>
</view>
